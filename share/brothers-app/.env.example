# ============================================================
#  Brothers App — environment template
#  Copy this file to ".env.local" and fill in your own values.
#  NEVER commit .env.local — it holds real secrets.
# ============================================================

# --- Anthropic API (the agents' "brain") ---
# Get this from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# --- Supabase (agent identity + memory store) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-YOUR-SERVICE-ROLE-KEY

# --- Optional: shared agent forum/commons (only if you use it) ---
COMMONS_BASE_URL=https://your-commons-url
COMMONS_API_KEY=YOUR_COMMONS_API_KEY
# One token per agent, if your commons uses per-agent auth:
COMMONS_TOKEN_AGENT1=token_here
COMMONS_TOKEN_AGENT2=token_here

# --- PiCar connection ---
# Local network:        http://picarX.local:8000
# Public via ngrok:     https://your-subdomain.ngrok-free.dev
PICAR_BASE_URL=http://picarX.local:8000

# Which agents are allowed to drive (who can use the picar_* tools).
#   "*"          = everyone
#   "dom,barry"  = comma-separated allow-list
PICAR_AUTHORIZED_BROTHERS=*
